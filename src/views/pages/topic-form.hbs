<div class="max-w-2xl mx-auto px-4 sm:px-6 py-10 space-y-6">
  <h1 class="font-bold text-gray-900 text-2xl">{{title}}</h1>
  
  {{#if error}}
    <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-600 text-sm">
      {{error}}
    </div>
  {{/if}}

  <form method="post" action="{{action}}" class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm space-y-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Tên chủ đề</label>
      <input type="text" name="name" value="{{topic.name}}" required class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900 focus:bg-white transition-colors" />
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Mô tả</label>
      <textarea name="description" rows="3" class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900 focus:bg-white transition-colors resize-none">{{topic.description}}</textarea>
    </div>



    <div class="pt-4 border-t border-gray-100 flex justify-end gap-3">
      <a href="/" class="px-5 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-xl font-medium hover:bg-gray-50 transition-colors">Hủy</a>
      <button type="submit" class="px-5 py-2.5 bg-gray-900 text-white rounded-xl font-medium hover:bg-gray-800 transition-colors">{{submitLabel}}</button>
    </div>
  </form>
</div>
