<div class="max-w-2xl mx-auto px-4 sm:px-6 py-10 space-y-6">
  <div class="flex items-center gap-3">
    <a href="/topics/{{topic.id}}" class="w-8 h-8 flex items-center justify-center rounded-lg border border-gray-200 text-gray-500 hover:border-gray-400 hover:text-gray-700 transition-colors shrink-0">
      <i data-lucide="arrow-left" class="w-4 h-4"></i>
    </a>
    <div class="flex-1">
      <h1 class="font-bold text-gray-900 text-2xl leading-none">Quiz · {{topic.name}}</h1>
      <p class="text-gray-500 text-sm mt-1 leading-none">Trả lời từ tiếng Anh tương ứng với nghĩa.</p>
    </div>
    <span class="text-sm font-medium text-gray-500 bg-gray-100 px-3 py-1.5 rounded-lg whitespace-nowrap" data-quiz-progress></span>
  </div>

  {{#if message}}
    <p class="text-center text-gray-500 py-10 bg-white border border-gray-200 rounded-2xl">{{message}}</p>
  {{else}}
    <div class="bg-white border border-gray-200 rounded-2xl p-6 sm:p-8 shadow-sm">
      <h2 class="text-xs text-gray-400 uppercase tracking-widest font-semibold mb-2" data-quiz-word></h2>
      <p class="text-xl font-bold text-gray-900 mb-4" data-quiz-definition></p>
      <p class="text-sm text-gray-600 italic mb-8" data-quiz-example></p>

      <form class="space-y-5" data-quiz-form>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Câu trả lời của bạn</label>
          <div class="relative">
            <input type="text" data-quiz-answer required autocomplete="off" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900 focus:bg-white transition-all text-lg font-medium" placeholder="Nhập từ tiếng Anh..." />
            <div id="feedback-icon" class="absolute right-4 top-1/2 -translate-y-1/2 hidden"></div>
          </div>
        </div>
        
        <div id="feedback-box" class="hidden rounded-xl p-4 text-sm font-medium transition-all">
          <p data-quiz-feedback></p>
        </div>

        <div class="flex gap-3 pt-2">
          <button type="submit" id="btn-submit" class="flex-1 py-3.5 bg-gray-900 text-white rounded-xl font-medium hover:bg-gray-800 transition-colors shadow-sm">Nộp bài</button>
          <button type="button" id="btn-next" class="flex-1 py-3.5 bg-white border border-gray-200 text-gray-700 rounded-xl font-medium hover:bg-gray-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed hidden" data-quiz-next>Tiếp theo</button>
        </div>
      </form>
    </div>
  {{/if}}
</div>
<script>
  window.__QUIZ_DATA__ = {{{toJson quizData}}};
</script>
<script type="module" src="/scripts/quiz.js"></script>
