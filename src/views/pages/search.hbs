<div class="max-w-3xl mx-auto px-4 sm:px-6 py-10 space-y-6">
  <div>
    <h1 class="font-bold text-gray-900 text-2xl">Tìm kiếm</h1>
    <p class="text-gray-500 text-sm mt-1">Tìm từ vựng trong tất cả các chủ đề.</p>
  </div>

  <form class="flex gap-3" method="get" action="/search">
    <div class="relative flex-1">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <i data-lucide="search" class="w-5 h-5 text-gray-400"></i>
      </div>
      <input
        type="search"
        name="q"
        placeholder="Tìm theo từ, định nghĩa hoặc câu ví dụ..."
        value="{{query}}"
        data-search-input
        class="w-full pl-10 pr-4 py-3 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900 transition-shadow shadow-sm"
      />
    </div>
    <button type="submit" class="px-6 py-3 bg-gray-900 text-white font-medium rounded-xl hover:bg-gray-800 transition-colors shadow-sm">Tìm</button>
  </form>

  <div class="flex items-center justify-between min-h-[1.5rem]">
    <p class="text-sm text-gray-500" data-search-status>
      {{#if results.length}}Tìm thấy {{results.length}} kết quả.{{/if}}
    </p>
  </div>

  <div data-search-results class="space-y-3">
    {{#if results.length}}
      {{#each results}}
        <div class="bg-white border border-gray-200 rounded-xl p-4 flex justify-between items-center hover:border-gray-900 transition-all group shadow-sm hover:shadow-md">
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-gray-900 group-hover:text-gray-900 transition-colors">{{this.word}}</h3>
            <p class="text-sm text-gray-500 mt-0.5 line-clamp-2">{{this.definition}}</p>
            <div class="flex items-center gap-2 mt-2">
              <span class="text-[10px] uppercase tracking-wider font-semibold text-gray-400">Chủ đề:</span>
              <a href="/topics/{{this.topicId}}" class="text-xs font-medium text-gray-600 hover:text-gray-900 hover:underline transition-colors">{{this.topicName}}</a>
            </div>
          </div>
          <div class="flex items-center gap-4 ml-4 shrink-0">
            <span class="hidden sm:inline-block text-[10px] font-bold px-2 py-1 rounded-lg uppercase tracking-wider bg-gray-100 text-gray-600">
              {{this.masteryLevel}}
            </span>
            <a href="/topics/{{this.topicId}}" class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-50 group-hover:bg-gray-900 group-hover:text-white text-gray-400 transition-all">
              <i data-lucide="arrow-right" class="w-5 h-5"></i>
            </a>
          </div>
        </div>
      {{/each}}
    {{else if query}}
      <div class="py-12 text-center bg-white border border-dashed border-gray-300 rounded-2xl">
        <i data-lucide="search-x" class="w-10 h-10 text-gray-300 mx-auto mb-3"></i>
        <p class="text-gray-500">Không tìm thấy từ nào phù hợp với "{{query}}"</p>
      </div>
    {{/if}}
  </div>
</div>
<script type="module" src="/scripts/search.js"></script>
