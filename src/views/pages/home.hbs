<div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 space-y-12">
  <!-- Header -->
  <div class="space-y-3">
    <h1 class="text-gray-900" style="font-size: 1.85rem; font-weight: 700; line-height: 1.2;">
      Học từ vựng tiếng Anh
    </h1>
    <p class="text-gray-500 max-w-lg">
      Học theo chủ đề với Flash Card. Lật thẻ để xem nghĩa, đánh dấu từ đã thuộc và theo dõi tiến trình của bạn.
    </p>

    {{#if isAuthed}}
      {{#if stats.totalWords}}
        <div class="flex items-center gap-6 pt-2">
          <div>
            <span class="text-2xl font-bold text-gray-900">{{stats.totalLearned}}</span>
            <span class="text-gray-400 text-sm ml-1.5">/ {{stats.totalWords}} từ đã học</span>
          </div>
          <div class="flex-1 max-w-xs h-1.5 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-full bg-gray-900 rounded-full transition-all duration-500" style="width: {{stats.progressPercent}}%"></div>
          </div>
        </div>
      {{/if}}
      <div class="flex items-center gap-3 pt-4">
        <a href="/dashboard" class="px-5 py-2.5 bg-gray-900 text-white rounded-xl text-sm font-medium hover:bg-gray-800 transition-colors">Tiếp tục học</a>
        <a href="/topics/new" class="px-5 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-xl text-sm font-medium hover:bg-gray-50 transition-colors">Tạo chủ đề mới</a>
      </div>
    {{else}}
      <div class="flex items-center gap-3 pt-4">
        <a href="/auth/login" class="px-5 py-2.5 bg-gray-900 text-white rounded-xl text-sm font-medium hover:bg-gray-800 transition-colors">Đăng nhập để bắt đầu</a>
        <a href="/auth/register" class="px-5 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-xl text-sm font-medium hover:bg-gray-50 transition-colors">Tạo tài khoản</a>
      </div>
    {{/if}}
  </div>

  <!-- Topic grid -->
  <div>
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-semibold text-gray-700" style="font-size: 0.95rem;">
        Tất cả chủ đề ({{topics.length}})
      </h2>
      <a href="/topics" class="text-sm text-gray-400 hover:text-gray-700 transition-colors flex items-center gap-1">
        Xem tất cả <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
      </a>
    </div>

    {{#if topics.length}}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {{#each topics}}
          <a href="/topics/{{this.id}}" class="group block h-full">
            <div class="bg-white border border-gray-200 rounded-xl p-5 hover:border-gray-400 hover:shadow-sm transition-all h-full flex flex-col">
              <div class="flex items-start justify-between mb-3">
                <span class="text-2xl">{{this.initial}}</span>
                <i data-lucide="chevron-right" class="w-4 h-4 text-gray-300 group-hover:text-gray-600 transition-colors mt-0.5"></i>
              </div>
              <h3 class="font-semibold text-gray-900">{{this.name}}</h3>
              <p class="text-sm text-gray-400 mt-0.5 line-clamp-2">{{this.description}}</p>

              <div class="mt-auto pt-5 space-y-1.5">
                <div class="flex items-center justify-between text-xs text-gray-400">
                  <span>{{this.learnedCount}}/{{this.totalCount}} từ</span>
                  {{#if this.learnedCount}}
                    <span>{{this.progressPercent}}%</span>
                  {{else}}
                    <span>Chưa bắt đầu</span>
                  {{/if}}
                </div>
                <div class="h-1 bg-gray-100 rounded-full overflow-hidden">
                  <div class="h-full rounded-full transition-all duration-500" style="width: {{this.progressPercent}}%; background-color: {{this.accentColor}};"></div>
                </div>
              </div>
            </div>
          </a>
        {{/each}}
      </div>
    {{else}}
      <p class="text-sm text-gray-500 py-4">Chưa có chủ đề nào. Hãy tạo chủ đề đầu tiên của bạn.</p>
    {{/if}}
  </div>

  <!-- How it works -->
  <div class="border-t border-gray-100 pt-10">
    <h2 class="font-semibold text-gray-700 mb-5" style="font-size: 0.95rem;">
      Cách sử dụng
    </h2>
    <div class="grid sm:grid-cols-3 gap-4">
      <div class="flex gap-3">
        <div class="w-7 h-7 rounded-full bg-gray-900 text-white flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">1</div>
        <div>
          <p class="font-medium text-gray-800 text-sm">Chọn chủ đề</p>
          <p class="text-gray-500 text-sm mt-0.5">Chọn chủ đề bạn muốn học hoặc cần dùng ngay.</p>
        </div>
      </div>
      <div class="flex gap-3">
        <div class="w-7 h-7 rounded-full bg-gray-900 text-white flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">2</div>
        <div>
          <p class="font-medium text-gray-800 text-sm">Lật thẻ</p>
          <p class="text-gray-500 text-sm mt-0.5">Nhấn thẻ để xem nghĩa, phát âm và câu ví dụ.</p>
        </div>
      </div>
      <div class="flex gap-3">
        <div class="w-7 h-7 rounded-full bg-gray-900 text-white flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">3</div>
        <div>
          <p class="font-medium text-gray-800 text-sm">Đánh dấu tiến trình</p>
          <p class="text-gray-500 text-sm mt-0.5">Theo dõi số thẻ đã học bằng màu sắc và biểu đồ.</p>
        </div>
      </div>
    </div>
  </div>
</div>
