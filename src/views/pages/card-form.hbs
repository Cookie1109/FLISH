<div class="max-w-2xl mx-auto px-4 sm:px-6 py-10 space-y-6">

  <!-- Header -->
  <div class="flex items-center gap-3">
    <a href="/topics/{{topic.id}}" class="w-8 h-8 flex items-center justify-center rounded-lg border border-gray-200 text-gray-500 hover:border-gray-400 hover:text-gray-700 transition-colors">
      <i data-lucide="arrow-left" class="w-4 h-4"></i>
    </a>
    <div>
      <h1 class="font-bold text-gray-900 text-xl">Thêm thẻ mới</h1>
      <p class="text-xs text-gray-400 mt-0.5">Chủ đề: <span class="font-medium text-gray-600">{{topic.name}}</span></p>
    </div>
  </div>

  {{#if error}}
    <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-600 text-sm flex items-center gap-2">
      <i data-lucide="alert-circle" class="w-4 h-4 shrink-0"></i>
      {{error}}
    </div>
  {{/if}}

  <form method="post" action="{{action}}" data-card-form id="card-form">

    <!-- Quick Add zone (prominent) -->
    <div class="bg-white border-2 border-gray-900 rounded-2xl p-6 shadow-sm space-y-4">
      <div class="flex items-center gap-2 mb-1">
        <div class="w-6 h-6 bg-gray-900 rounded-full flex items-center justify-center">
          <i data-lucide="zap" class="w-3.5 h-3.5 text-white"></i>
        </div>
        <span class="font-semibold text-gray-900">Thêm nhanh</span>
      </div>
      <p class="text-sm text-gray-500">Chỉ cần nhập từ tiếng Anh, hệ thống sẽ <strong class="text-gray-800">tự động điền</strong> phiên âm, nghĩa tiếng Việt và hình ảnh.</p>

      <div class="relative">
        <input
          type="text"
          name="word"
          id="word-input"
          value="{{card.word}}"
          required
          autocomplete="off"
          placeholder="Nhập từ tiếng Anh, ví dụ: abundant"
          class="w-full px-5 py-4 text-xl font-semibold bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900 focus:bg-white transition-all placeholder:font-normal placeholder:text-base placeholder:text-gray-400"
        />
      </div>

      <!-- Auto-fill status -->
      <div id="lookup-status" class="hidden items-center gap-2 text-sm text-gray-500 bg-gray-50 rounded-xl px-4 py-3">
        <div id="lookup-spinner" class="hidden w-4 h-4 border-2 border-gray-300 border-t-gray-700 rounded-full animate-spin"></div>
        <i data-lucide="check-circle" id="lookup-ok-icon" class="hidden w-4 h-4 text-green-500"></i>
        <i data-lucide="x-circle" id="lookup-err-icon" class="hidden w-4 h-4 text-red-400"></i>
        <span id="lookup-text"></span>
      </div>

      <!-- Preview card (shows after lookup) -->
      <div id="preview-card" class="hidden rounded-xl border border-gray-200 overflow-hidden">
        <div class="flex items-start gap-3 p-4">
          <img id="preview-image" src="" alt="" class="hidden w-16 h-16 rounded-lg object-cover shrink-0" />
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
              <span id="preview-word" class="font-bold text-gray-900 text-lg"></span>
              <span id="preview-phonetic" class="text-gray-400 text-sm font-mono"></span>
              <span id="preview-pos" class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full"></span>
            </div>
            <p id="preview-definition" class="text-sm text-gray-700 mt-1 font-medium"></p>
            <p id="preview-example" class="text-xs text-gray-400 mt-1 italic"></p>
            <p id="preview-translation" class="text-xs text-gray-500 mt-0.5"></p>
          </div>
        </div>
      </div>

      <!-- Submit button -->
      <button
        type="submit"
        id="submit-btn"
        class="w-full py-3 bg-gray-900 text-white rounded-xl font-semibold hover:bg-gray-800 active:scale-[0.98] transition-all flex items-center justify-center gap-2"
      >
        <i data-lucide="plus" class="w-4 h-4"></i>
        Thêm thẻ vào chủ đề
      </button>
    </div>

    <!-- Hidden fields (filled by lookup) -->
    <input type="hidden" name="phonetic" id="field-phonetic" value="{{card.phonetic}}" />
    <input type="hidden" name="audioUrl" id="field-audioUrl" value="{{card.audioUrl}}" />
    <input type="hidden" name="partOfSpeech" id="field-partOfSpeech" value="{{card.partOfSpeech}}" />
    <input type="hidden" name="imageUrl" id="field-imageUrl" value="{{card.imageUrl}}" />
    <input type="hidden" name="definition" id="field-definition" value="{{card.definition}}" />
    <input type="hidden" name="exampleSentence" id="field-exampleSentence" value="{{card.exampleSentence}}" />
    <input type="hidden" name="exampleTranslation" id="field-exampleTranslation" value="{{card.exampleTranslation}}" />


  </form>
</div>

<script type="module">
  import { speakText } from '/scripts/speech.js';

  const wordInput = document.getElementById('word-input');
  const lookupStatus = document.getElementById('lookup-status');
  const lookupSpinner = document.getElementById('lookup-spinner');
  const lookupOkIcon = document.getElementById('lookup-ok-icon');
  const lookupErrIcon = document.getElementById('lookup-err-icon');
  const lookupText = document.getElementById('lookup-text');
  const previewCard = document.getElementById('preview-card');
  const submitBtn = document.getElementById('submit-btn');

  // Hidden fields
  const fields = {
    phonetic: document.getElementById('field-phonetic'),
    audioUrl: document.getElementById('field-audioUrl'),
    partOfSpeech: document.getElementById('field-partOfSpeech'),
    definition: document.getElementById('field-definition'),
    exampleSentence: document.getElementById('field-exampleSentence'),
    exampleTranslation: document.getElementById('field-exampleTranslation'),
    imageUrl: document.getElementById('field-imageUrl'),
  };

  // Override fields (manual inputs in the advanced section)
  document.querySelectorAll('.override-field').forEach(el => {
    el.addEventListener('input', () => {
      const key = el.dataset.field;
      if (fields[key]) fields[key].value = el.value;
    });
  });

  let debounceTimer = null;
  let lastLookedUp = '';
  let lookupData = null;

  function showStatus(state, text) {
    lookupStatus.classList.remove('hidden');
    lookupStatus.classList.add('flex');
    lookupSpinner.classList.add('hidden');
    lookupOkIcon.classList.add('hidden');
    lookupErrIcon.classList.add('hidden');

    if (state === 'loading') {
      lookupSpinner.classList.remove('hidden');
    } else if (state === 'ok') {
      lookupOkIcon.classList.remove('hidden');
    } else if (state === 'error') {
      lookupErrIcon.classList.remove('hidden');
    }
    lookupText.textContent = text;
  }

  function hideStatus() {
    lookupStatus.classList.add('hidden');
    lookupStatus.classList.remove('flex');
  }

  function showPreview(data) {
    document.getElementById('preview-word').textContent = data.word || '';
    document.getElementById('preview-phonetic').textContent = data.phonetic || '';
    document.getElementById('preview-pos').textContent = data.partOfSpeech || '';
    document.getElementById('preview-definition').textContent = data.definition || '(Chưa có định nghĩa)';
    document.getElementById('preview-example').textContent = data.exampleSentence ? `"${data.exampleSentence}"` : '';
    document.getElementById('preview-translation').textContent = data.exampleTranslation ? `→ ${data.exampleTranslation}` : '';

    const imgEl = document.getElementById('preview-image');
    if (data.imageUrl) {
      imgEl.src = data.imageUrl;
      imgEl.classList.remove('hidden');
    } else {
      imgEl.classList.add('hidden');
    }

    previewCard.classList.remove('hidden');

    // Sync hidden fields (only if override fields are empty)
    for (const [key, el] of Object.entries(fields)) {
      if (!el.value) el.value = data[key] || '';
    }


  }

  function hidePreview() {
    previewCard.classList.add('hidden');
    // Reset hidden fields
    for (const el of Object.values(fields)) el.value = '';
  }

  async function doLookup(word) {
    if (!word || word === lastLookedUp) return;
    lastLookedUp = word;
    lookupData = null;

    showStatus('loading', `Đang tra từ "${word}"...`);
    hidePreview();

    const token = localStorage.getItem('flish_id_token');
    try {
      const res = await fetch(`/api/lookup/${encodeURIComponent(word)}`, {
        headers: token ? { Authorization: `Bearer ${token}` } : {},
      });

      if (!res.ok) {
        showStatus('error', `Không tìm thấy từ "${word}".`);
        return;
      }

      const data = await res.json();
      lookupData = data;

      showStatus('ok', `Đã tìm thấy thông tin cho "${word}". Kiểm tra xem trước khi thêm.`);
      showPreview(data);
    } catch (err) {
      showStatus('error', 'Lỗi kết nối.');
    }
  }

  wordInput.addEventListener('input', () => {
    const word = wordInput.value.trim();
    if (!word) {
      hideStatus();
      hidePreview();
      lastLookedUp = '';
      return;
    }

    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => doLookup(word), 600);
  });

  // On form submit: show loading state
  document.getElementById('card-form').addEventListener('submit', () => {
    submitBtn.disabled = true;
    submitBtn.innerHTML = `
      <div class="w-4 h-4 border-2 border-white/40 border-t-white rounded-full animate-spin"></div>
      Đang thêm...
    `;
  });
</script>
